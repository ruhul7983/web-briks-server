generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- User Management ---
enum Role {
  ADMIN
  MODERATOR
}

enum Site {
  WEBBRIKS
  ASHAD
  PORTFOLIO_THREE
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MODERATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Content Taxonomy ---
model Category {
  id            Int           @id @default(autoincrement())
  site          Site          @default(WEBBRIKS)
  name          String
  slug          String
  subcategories Subcategory[]
  blogs         Blog[]
  projects      Project[]     // Added relation to Projects
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([name, site])
  @@unique([slug, site])
}

model Subcategory {
  id         Int       @id @default(autoincrement())
  site       Site      @default(WEBBRIKS)
  name       String
  slug       String
  categoryId Int
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  blogs      Blog[]
  projects   Project[] // Added relation to Projects
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([name, categoryId])
  @@unique([slug, site])
}

// --- Blog System ---
model Blog {
  id              Int          @id @default(autoincrement())
  site            Site         @default(WEBBRIKS)
  title           String
  slug            String
  author          String       @default("Admin")
  readTime        String?
  badge           String?
  image           String?
  featured        Boolean      @default(false)
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  status          String       @default("published")
  
  // Relations
  categoryId      Int?
  category        Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId   Int?
  subcategory     Subcategory? @relation(fields: [subcategoryId], references: [id])

  description     Json
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([slug, site])
}

// --- Project Portfolio System ---
model Project {
  id              Int          @id @default(autoincrement())
  site            Site         @default(WEBBRIKS)
  title           String
  slug            String
  
  // Project Specific Fields
  clientName      String
  impactAreas     String[]
  startDate       DateTime
  clientLocation  String
  
  // Relations (Now matches Blog system)
  categoryId      Int?
  category        Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId   Int?
  subcategory     Subcategory? @relation(fields: [subcategoryId], references: [id])

  // Media & SEO
  image           String?
  featured        Boolean      @default(false)
  status          String       @default("published")
  metaTitle       String?
  metaDescription String?
  keywords        String[]

  description     Json
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([slug, site])
}