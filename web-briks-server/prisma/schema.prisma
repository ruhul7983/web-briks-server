generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- User Management ---
enum Role {
  ADMIN
  MODERATOR
}

// --- Multi-Site Configuration ---
// To add a new portfolio, simply add a new value to this enum
enum Site {
  WEBBRIKS
  ASHAD
  PORTFOLIO_THREE // Example for future expansion
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MODERATOR) // New users default to Moderator for safety
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Content Taxonomy ---
model Category {
  id            Int           @id @default(autoincrement())
  site          Site          @default(WEBBRIKS) // Defaulting as requested
  name          String
  slug          String
  subcategories Subcategory[]
  blogs         Blog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Name and Slug must be unique PER SITE, not across the whole DB
  @@unique([name, site])
  @@unique([slug, site])
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  site       Site     @default(WEBBRIKS)
  name       String
  slug       String
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  blogs      Blog[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Ensures subcategory name is unique within its parent category and site
  @@unique([name, categoryId])
  @@unique([slug, site])
}

// --- Blog System ---
model Blog {
  id       Int     @id @default(autoincrement())
  site     Site    @default(WEBBRIKS)
  title    String
  slug     String
  author   String  @default("Admin")
  readTime String?
  badge    String?
  image    String?
  featured Boolean @default(false)

  // SEO Fields
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  status          String   @default("published")

  // Relations
  categoryId    Int?
  category      Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId Int?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  // Content
  description Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Slug must be unique per site
  @@unique([slug, site])
}
